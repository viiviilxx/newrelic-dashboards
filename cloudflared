{
  "name": "Cloudflared Overview (OTel)",
  "description": "Cloudflared metrics collected via OpenTelemetry Collector",
  "permissions": "PUBLIC_READ_ONLY",
  "pages": [
    {
      "name": "Cloudflared Performance & System",
      "description": "",
      "widgets": [
        {
          "title": "HA Connections",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT latest(cloudflared_tunnel_ha_connections) FROM Metric"
              }
            ],
            "thresholds": [
              {
                "alertSeverity": "CRITICAL",
                "value": 2
              },
              {
                "alertSeverity": "WARNING",
                "value": 3
              }
            ]
          }
        },
        {
          "title": "Tunnel Edge Locations",
          "layout": {
            "column": 5,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.pie"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT latest(cloudflared_tunnel_server_locations) FROM Metric FACET edge_location"
              }
            ]
          }
        },
        {
          "title": "QUIC Smoothed RTT (ms)",
          "layout": {
            "column": 9,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(quic_client_smoothed_rtt) FROM Metric FACET conn_index TIMESERIES"
              }
            ]
          }
        },
        {
          "title": "QUIC Traffic Rate (Bytes/sec)",
          "layout": {
            "column": 1,
            "row": 4,
            "width": 6,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.area"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT rate(average(quic_client_receive_bytes), 1 second) as 'Received', rate(average(quic_client_sent_bytes), 1 second) as 'Sent' FROM Metric FACET conn_index TIMESERIES"
              }
            ]
          }
        },
        {
          "title": "Active TCP / UDP Sessions",
          "layout": {
            "column": 7,
            "row": 4,
            "width": 6,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT latest(cloudflared_tcp_active_sessions) as 'TCP', latest(cloudflared_udp_active_sessions) as 'UDP' FROM Metric TIMESERIES"
              }
            ]
          }
        },
        {
          "title": "Process Memory Usage (MB)",
          "layout": {
            "column": 1,
            "row": 7,
            "width": 6,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(process_resident_memory_bytes) / 1024 / 1024 as 'RSS (Resident)', average(process_virtual_memory_bytes) / 1024 / 1024 as 'VMS (Virtual)' FROM Metric TIMESERIES"
              }
            ]
          }
        },
        {
          "title": "Goroutines & Threads",
          "layout": {
            "column": 7,
            "row": 7,
            "width": 6,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT latest(go_goroutines) as 'Goroutines', latest(go_threads) as 'Threads' FROM Metric TIMESERIES"
              }
            ]
          }
        }
      ]
    }
  ],
  "variables": []
}
